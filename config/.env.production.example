# POLYROB Production Environment Configuration — TEMPLATE
#
# Copy this file to `config/.env.production` and fill in real values.
# This `.example` file is committed and MUST contain NO real secrets.
#   cp config/.env.production.example config/.env.production
#
# Anything marked `# CHANGE_ME` is required before going live. Generate strong
# random values for the security keys (e.g. `openssl rand -hex 32`).

# ===========================================
# CORE CONFIGURATION
# ===========================================
ENVIRONMENT=production

# ===========================================
# API CONFIGURATION
# ===========================================
API_HOST=127.0.0.1
API_PORT=9000
# Bearer token guarding the REST/A2A surface. CHANGE_ME (random).
API_AUTH_TOKEN=

# ===========================================
# DATABASE & STORAGE PATHS
# ===========================================
# Data-home OUTSIDE the code tree so the agent workspace is never a sibling of
# this secrets file. See docs/guide/self-hosting.md.
POLYROB_DATA_DIR=/var/lib/polyrob
DATA_DIR=/var/lib/polyrob/data
CHARACTERS_DIR=/var/lib/polyrob/data/characters
KNOWLEDGE_DIR=/var/lib/polyrob/data/knowledge
CACHE_DIR=/var/lib/polyrob/data/cache
DB_PATH=/var/lib/polyrob/data/bot.db
CACHE_SIZE=1000

# ===========================================
# BROWSER CONFIGURATION
# ===========================================
PLAYWRIGHT_BROWSERS_PATH=/var/lib/polyrob/.cache/ms-playwright
PLAYWRIGHT_BROWSER_TIMEOUT=120000
BROWSER_DISABLE_SECURITY=true
BROWSER_HEADLESS=true
CHROME_PATH=
MAX_BROWSER_CONTEXTS=25

# ===========================================
# WEBVIEW / WEBGATE CONFIGURATION
# ===========================================
WEBVIEW_HOST=127.0.0.1
WEBVIEW_PORT=5050
# Single-user webgate by default. Set WEBGATE_MULTITENANT=true only for a
# multi-tenant hosted deployment (signin/profile/admin).
# WEBGATE_MULTITENANT=false

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# ===========================================
# LLM PROVIDER API KEYS (at least one required) — CHANGE_ME
# ===========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# OpenRouter (Grok, Kimi, Qwen, and 100+ models via one API)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=POLYROB AI Agent

# NVIDIA NIM (optional)
NIM_API_KEY=

# ===========================================
# SEARCH & OTHER SERVICES (optional)
# ===========================================
PERPLEXITY_API_KEY=

# ===========================================
# SOCIAL MEDIA — Twitter/X (optional)
# ===========================================
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET_KEY=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BOT_USER_ID=
TWITTER_BOT_USERNAME=

# ===========================================
# TELEGRAM SURFACE (optional)
# ===========================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_OWNER_ID=

# ===========================================
# EMAIL / GMAIL SURFACE (optional)
# ===========================================
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587

# ===========================================
# BLOCKCHAIN / CRYPTO (optional — OFF by default)
# ===========================================
ALCHEMY_API_KEY=
COLLABLAND_API_ID=
COLLABLAND_API_SECRET=
COLLABLAND_API_KEY=

# ===========================================
# MEMORY SYSTEM
# ===========================================
# sqlite (default, FTS keyword) | local_vector (hybrid, needs sqlite-vec) | none
MEMORY_BACKEND=sqlite
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ===========================================
# MODEL CONFIGURATION
# ===========================================
MODEL_PROVIDER=anthropic
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096

# ===========================================
# MCP (Model Context Protocol)
# ===========================================
MCP_ENABLED=true
# Fernet key encrypting the MCP/OAuth secret store. CHANGE_ME (random).
MCP_ENCRYPTION_KEY=

# ===========================================
# SECURITY / AUTH SECRETS — CHANGE_ME (generate strong random values)
# ===========================================
ENABLE_AUTH=true
# `openssl rand -hex 32`
JWT_SECRET_KEY=
# Wallet derivation seed — changing this changes every derived wallet address.
MASTER_SEED=
PAYMENT_MASTER_SEED=
