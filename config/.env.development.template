# POLYROB Development Environment Configuration
# Production server example: YOUR_SERVER_IP - https://your-polyrob-host.example/

# ===========================================
# CORE CONFIGURATION
# ===========================================
ENVIRONMENT=development

# ===========================================
# API CONFIGURATION
# ===========================================
API_HOST=127.0.0.1
API_PORT=9000
API_AUTH_TOKEN=generate-secure-token-here

# ===========================================
# DATABASE & STORAGE PATHS (Server paths)
# ===========================================
# Server data-home OUTSIDE the code tree (install/data split — doc 01/06).
POLYROB_DATA_DIR=/var/lib/polyrob
DATA_DIR=/opt/polyrob/data
CHARACTERS_DIR=/opt/polyrob/data/characters
KNOWLEDGE_DIR=/opt/polyrob/data/knowledge
CACHE_DIR=/opt/polyrob/data/cache
DB_PATH=/opt/polyrob/data/bot.db
CACHE_SIZE=1000

# ===========================================
# BROWSER CONFIGURATION
# ===========================================
PLAYWRIGHT_BROWSERS_PATH=/opt/polyrob/.cache/ms-playwright
PLAYWRIGHT_BROWSER_TIMEOUT=120000
BROWSER_DISABLE_SECURITY=true
BROWSER_HEADLESS=false
CHROME_PATH=
MAX_BROWSER_CONTEXTS=25

# ===========================================
# WEBVIEW CONFIGURATION
# ===========================================
WEBVIEW_HOST=0.0.0.0
WEBVIEW_PORT=3000
WEBVIEW_DOMAIN=localhost:3000

# ===========================================
# TELEMETRY CONFIGURATION
# ===========================================
TELEMETRY_ENABLED=false
TELEMETRY_LOG_LEVEL=info
TELEMETRY_DATA_DIR=/opt/polyrob/data/auto/telemetry
TELEMETRY_BUFFER_SIZE=500
TELEMETRY_BUFFER_TIMEOUT=60.0

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=DEBUG
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
HTTP_LOG_FORMAT="%(asctime)s - %(name)s - HTTP %(method)s %(url)s %(status_code)d %(reason_phrase)s"

# ===========================================
# API KEYS
# ===========================================
# OpenAI
OPENAI_API_KEY=<REPLACE_ME>

# Anthropic
ANTHROPIC_API_KEY=<REPLACE_ME>

# Deepseek
DEEPSEEK_API_KEY=<REPLACE_ME>

# Google 
GEMINI_API_KEY=<REPLACE_ME>

# Meta

# OpenRouter (Grok, Kimi, Qwen, and 100+ models via unified API)
# Get your API key from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://your-polyrob-host.example
OPENROUTER_SITE_NAME=POLYROB AI Agent

# Search and other services
PERPLEXITY_API_KEY=<REPLACE_ME>

# Social media
TWITTER_BEARER_TOKEN=<REPLACE_ME>
TWITTER_API_KEY=<REPLACE_ME>
TWITTER_API_SECRET_KEY=<REPLACE_ME>
TWITTER_ACCESS_TOKEN=<REPLACE_ME>
TWITTER_ACCESS_TOKEN_SECRET=<REPLACE_ME>
TWITTER_BOT_USER_ID=<REPLACE_ME>
TWITTER_BOT_USERNAME=tmachinrobot

# Vector database
PINECONE_API_KEY=<REPLACE_ME>
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=testovich-dev
PINECONE_DIMENSION=384
PINECONE_METRIC=cosine

# Embedding models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Gmail configuration
GMAIL_EMAIL=your.email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587

ENABLE_RESOURCE_MONITORING=true

ALCHEMY_API_KEY=<REPLACE_ME>

COLLABLAND_API_ID=<REPLACE_ME>
COLLABLAND_API_SECRET=<REPLACE_ME>
COLLABLAND_API_KEY=<REPLACE_ME>

DEN_TOKEN_CONTRACT_ADDRESS=0xb0d79432bb6d163d3832157cff61a918d38aab81

# ===========================================
# AUTO AGENT SETTINGS
# ===========================================
AUTO_AGENT_ENABLED=false
AUTO_CYCLE_INTERVAL=60
AUTO_MIN_DELAY=5
AUTO_MAX_DELAY=15
AUTO_MAX_ACTIONS_PER_CYCLE=3
AUTO_ALLOWED_SERVICES=twitter,browser,perplexity,websearch,knowledge,loom,email
AUTO_KNOWLEDGE_RETENTION_DAYS=7
AUTO_METRICS_ENABLED=true

# ===========================================
# SERVICE CONFIGURATION
# ===========================================
SERVICES_OCR_ENABLED=true
SERVICES_BROWSER_ENABLED=true
SERVICES_TWITTER_ENABLED=true
SERVICES_PERPLEXITY_ENABLED=true
SERVICES_WEBSEARCH_ENABLED=true
SERVICES_KNOWLEDGE_ENABLED=true
SERVICES_LOOM_ENABLED=true
SERVICES_EMAIL_ENABLED=true

# ===========================================
# MODEL CONFIGURATION
# ===========================================
MODEL_NAME=claude-3-5-sonnet-20241022
MODEL_PROVIDER=anthropic
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096

# ===========================================
# DOCUMENT PROCESSOR SETTINGS
# ===========================================
DOC_MAX_FILE_SIZE=20971520
DOC_MAX_TEXT_LENGTH=100000
DOC_CHUNK_SIZE=4096
DOC_CACHE_TTL=3600

# ===========================================
# CHARACTER CONFIGURATION
# ===========================================
DEFAULT_CHARACTER=rob
CHARACTERS_DIR=/opt/polyrob/agents/personality/characters

# ===========================================
# BROWSER USE CONFIGURATION
# ===========================================
BROWSER_USE_LOGGING_LEVEL=info
ANONYMIZED_TELEMETRY=false

# ===========================================
# MCP (Model Context Protocol) CONFIGURATION
# ===========================================
MCP_ENABLED=true
MCP_SERVERS_CONFIG='{}'

# ===========================================
# PYTHONPATH CONFIGURATION
# ===========================================
PYTHONPATH=/opt/polyrob

# ===========================================
# AUTOV2 PERFORMANCE OPTIMIZATIONS
# ===========================================
# Content limits - increased for better context
PAGE_CONTENT_TRUNCATE_LENGTH=8000
LARGE_CONTENT_PREVIEW_LENGTH=5000
MAX_EXTRACTED_CONTENT_LENGTH=500000

# Memory optimization
ENABLE_GIF_CREATION=false
SCREENSHOT_JPEG_QUALITY=70
MAX_MEMORY_CACHE_SIZE=30
MEMORY_CLEANUP_INTERVAL=50

# Parse retry configuration - balanced for reliability
MAX_PARSE_RETRIES=3
BASE_RETRY_DELAY=1
MAX_RETRY_DELAY=5
BACKOFF_MULTIPLIER=1.5

# Loop detection - less aggressive
MAX_REPETITIONS=15
UNCHANGED_STATE_THRESHOLD=20
MAX_CONSECUTIVE_FAILURES=5

# Browser context
SHARED_BROWSER=false
BROWSER_CONTEXT_TIMEOUT=300000

# Early termination prevention
CONFIDENCE_CHECK_BEFORE_DONE=true
MIN_STEPS_BEFORE_DONE=3
TASK_VERIFICATION_REQUIRED=true

# User interaction
ENABLE_UNSTUCK_COMMAND=true
USER_GUIDANCE_NON_BLOCKING=true
MAX_USER_GUIDANCE_TOKENS=1500

# ===========================================
# SESSION MEMORY MANAGEMENT (Continuous Chat)
# ===========================================
# TTL-based eviction - sessions inactive longer than this are evicted
SESSION_TTL_SECONDS=3600

# LRU-based eviction - max sessions kept in memory
MAX_SESSIONS_IN_MEMORY=100

# Cleanup interval - how often to check for eviction
SESSION_CLEANUP_INTERVAL=300

# Per-user session limits - max concurrent sessions per user
MAX_SESSIONS_PER_USER=10

# ===========================================
# HIERARCHICAL MEMORY SYSTEM (Phase 2)
# ===========================================
# Enable/disable hierarchical memory system for task agent
HIERARCHICAL_MEMORY_ENABLED=true

# Enable message compaction
COMPACTION_ENABLED=true

# Context size thresholds
CONTEXT_SOFT_THRESHOLD=0.70
CONTEXT_HARD_THRESHOLD=0.85

# Memory window settings
MAX_RECENT_STEPS=20
TOOL_RESULT_MAX_AGE=10
ENABLE_AUTH=true
JWT_SECRET_KEY=REPLACE_WITH_SECURE_KEY
PAYMENT_MASTER_SEED=REPLACE_WITH_SECURE_SEED
