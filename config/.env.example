# POLYROB — example environment file.
#
# Copy this to a real env file and fill in at least one provider key:
#   cp config/.env.example config/.env.development      # local / docker-compose
#   cp config/.env.example config/.env.production       # server (also set secrets below)
#
# docker-compose.yml reads this file directly so `docker compose up` works on a fresh
# clone; replace the placeholder key with a real one before expecting the agent to run.
# The CLI (`polyrob init`) writes ~/.polyrob/.env instead — this file is for the
# server / container path. Never commit a filled-in copy (real env files are gitignored).

# --- LLM provider (set at least one) ---------------------------------------------
# OpenRouter is recommended: one key reaches every model.
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- Server / container ----------------------------------------------------------
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=1
LOG_LEVEL=info

# --- Data + memory ---------------------------------------------------------------
# Where runtime state (sqlite DBs, agent workspaces) lives. In docker this is a volume.
POLYROB_DATA_DIR=/app/.polyrob
MEMORY_BACKEND=sqlite

# --- Auth secrets (server only) --------------------------------------------------
# Generate unique per-deployment values — NEVER reuse a committed secret:
#   openssl rand -hex 32
JWT_SECRET_KEY=
PAYMENT_MASTER_SEED=
